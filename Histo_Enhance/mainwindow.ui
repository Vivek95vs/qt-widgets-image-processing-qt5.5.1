    <property name="styleSheet">
     <string notr="true">QSlider {
    background: rgb(240, 240, 240); /* Slider background */
}

QSlider::groove:horizontal {
    height: 10px;
    width: 215px;
    background: rgb(240, 240, 240);
    border: 1px solid rgb(10, 182, 242); /* Corrected border property */
    border-radius: 10px;
}

QSlider::handle:horizontal {
    background: rgb(10, 182, 242);
    width: 14px;
    margin: -3px;
 	border: 1px solid rgb(50, 50, 50);
    border-radius: 7px;
}

QSlider::sub-page:horizontal {
    background: rgb(10, 182, 242); /* Color of the slider track filled as the handle moves */
    border-radius: 10px;
}</string>
    </property>
    <property name="orientation">
     <enum>Qt::Horizontal</enum>
    </property>
   </widget>
